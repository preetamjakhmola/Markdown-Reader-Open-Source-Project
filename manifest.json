{
  "manifest_version": 3,
  "name": "Markdown Reader - Open Source Project",
  "version": "1.0",
  "description": "Read and view markdown files in browser. [Allow access to file URLs from extension settings]",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "js": ["marked.min.js", "content.js"],
      "css": ["viewer.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["folder-viewer.html", "folder-viewer.js", "folder-viewer.css", "marked.min.js"],
      "matches": ["file:///*"]
    }
  ]
}
